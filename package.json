{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "k8o",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless proxy start --https && turbo run dev",
    "build": "turbo run build",
    "check": "vp check",
    "check:write": "vp check --fix",
    "ls-lint": "ls-lint",
    "inspect": "vp-inspect",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "storybook": "turbo run storybook",
    "turbo:devtools": "turbo devtools",
    "install-playwright": "playwright install --with-deps chromium",
    "knip": "knip"
  },
  "devDependencies": {
    "@k8o/oxc-config": "0.2.0",
    "@ls-lint/ls-lint": "2.3.1",
    "@types/node": "24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260706.1",
    "knip": "6.24.0",
    "oxlint-tailwindcss": "1.3.4",
    "playwright": "1.61.1",
    "portless": "0.15.1",
    "turbo": "2.10.3",
    "typescript": "6.0.3",
    "vite-plus": "0.2.2",
    "vite-plus-inspector": "0.1.0",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "pnpm@11.11.0"
}
