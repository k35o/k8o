{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "k8o",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless proxy start --https && turbo run dev",
    "build": "turbo run build",
    "check": "vp check",
    "check:write": "vp check --fix",
    "ls-lint": "ls-lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "storybook": "turbo run storybook",
    "turbo:devtools": "turbo devtools",
    "install-playwright": "playwright install --with-deps chromium",
    "knip": "knip"
  },
  "devDependencies": {
    "@k8o/oxc-config": "0.1.2",
    "@ls-lint/ls-lint": "2.3.1",
    "@oxlint/plugins": "1.66.0",
    "@types/node": "24.12.4",
    "@typescript/native-preview": "7.0.0-dev.20260525.1",
    "@vercel/next-browser": "0.7.1",
    "knip": "6.14.2",
    "oxlint-tailwindcss": "1.1.0",
    "playwright": "1.60.0",
    "portless": "0.13.0",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "vite-plus": "0.1.22"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "pnpm@11.3.0"
}
