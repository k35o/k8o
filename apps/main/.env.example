TURSO_DATABASE_URL="https://db.k8o.localhost"
TURSO_AUTH_TOKEN=dummy
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
GITHUB_TOKEN=
VAPID_PUBLIC_KEY=
# admin からの /api/revalidate 呼び出しを認可する共有 secret（未設定なら常に401）
REVALIDATE_SECRET=
# --- Sakana Fugu (Reading の AI 要約生成) ---
# 秘密は fnox に登録済み。ローカルは `fnox exec -- pnpm run dev` で注入する。
SAKANA_API_KEY=
# 任意: Fugu の baseURL（既定 https://api.sakana.ai/v1）
SAKANA_BASE_URL=
# 任意: 要約に使う Fugu のモデル ID（既定 fugu）
SUMMARY_MODEL=
