TURSO_DATABASE_URL="https://db.k8o.localhost"
TURSO_AUTH_TOKEN=dummy
ALLOWED_EMAILS=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://ai.k8o.localhost/
# ローカル開発でログインを省略する（NODE_ENV=development のときのみ有効。本番では無視される）
LOCAL_AUTH_BYPASS=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# --- Sakana Fugu (生成) ---
# 秘密は fnox に登録済み。ローカルは `fnox exec -- pnpm run dev` で注入する。
SAKANA_API_KEY=
# --- プレビュー ---
# ローカル開発: sandbox-template の Vite dev server URL（既定 http://localhost:5199）
AI_LOCAL_PREVIEW_URL=http://localhost:5199
# --- Vercel Sandbox (本番プレビュー) ---
AI_TEMPLATE_SNAPSHOT_ID=
# ローカルのみ: `vercel env pull` で取得する。本番では Vercel が自動注入するため手動設定しない
VERCEL_OIDC_TOKEN=
