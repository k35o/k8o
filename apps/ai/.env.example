TURSO_DATABASE_URL="https://db.k8o.localhost"
TURSO_AUTH_TOKEN=dummy
ALLOWED_EMAILS=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://ai.k8o.localhost/
# ローカル開発でログインを省略する（NODE_ENV=development のときのみ有効。本番では無視される）
LOCAL_AUTH_BYPASS=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# --- Sakana Fugu (生成) ---
# 秘密は fnox に登録済み。ローカルは `fnox exec -- pnpm run dev` で注入する。
SAKANA_API_KEY=
# 生成のレート制限（1ユーザーあたり直近1時間の上限。既定 60）。暴走時のコスト抑制。
AI_GENERATE_LIMIT_PER_HOUR=60
# --- プレビュー / 共有（常に Vercel Sandbox。ローカルも同じ経路）---
# snapshot ID は通常 template-snapshot.ts（bake が自動生成・コミット管理）を使うため設定不要。
# 別の snapshot を一時的に試したいときだけ、ここで上書きできる（任意）。
AI_TEMPLATE_SNAPSHOT_ID=
# ローカルから Sandbox を起こすための Vercel 認証。fnox の VERCEL_TOKEN を使う想定:
#   fnox exec -- pnpm run dev
# OIDC を使う場合は `vercel env pull` で取得する。本番では Vercel が自動注入するため手動設定しない。
VERCEL_OIDC_TOKEN=
