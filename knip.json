{
  "$schema": "https://unpkg.com/knip/schema.json",
  "ignore": [
    "apps/main/public/sw.js",
    "apps/main/public/playgrounds/shared-worker.worker.js",
    "apps/ai/sandbox-template/**"
  ],
  "treatConfigHintsAsErrors": true,
  "tags": ["-lintignore"],
  "ignoreBinaries": ["mise", "which"],
  "workspaces": {
    ".": {
      "entry": ["vite.config.ts"],
      "ignoreDependencies": ["@vercel/next-browser"]
    },
    "apps/main": {
      "ignoreDependencies": ["chromatic"]
    },
    "apps/admin": {
      "ignoreDependencies": ["chromatic"]
    },
    "apps/ai": {
      "ignoreDependencies": ["chromatic"]
    }
  }
}
