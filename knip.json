    "apps/main/src/app/_components/development-only/development-only.tsx",
    "apps/main/src/app/_components/development-only/index.ts"
  ],
  "treatConfigHintsAsErrors": true,
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
