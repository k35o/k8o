{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["NODE_ENV", "PORTLESS_URL", "VERCEL_ENV"],
  "globalPassThroughEnv": [
    "CRON_SECRET",
    "GITHUB_TOKEN",
    "K8O_PUSH_API_KEY",
    "MAIN_REVALIDATE_URL",
    "REVALIDATE_SECRET"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AI_SHARE_SERVE_LIMIT_PER_HOUR",
        "AI_TEMPLATE_SNAPSHOT_ID",
        "ALLOWED_EMAILS",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "NEXT_PUBLIC_GOOGLE_ANALYTICS_ID",
        "SAKANA_API_KEY",
        "TURSO_AUTH_TOKEN",
        "TURSO_DATABASE_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "type-check": {
      "dependsOn": ["transit"],
      "outputs": ["tsconfig.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["transit"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    }
  }
}
