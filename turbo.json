{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["NODE_ENV", "VERCEL_ENV"],
  "globalPassThroughEnv": [
    "ANALYZE",
    "CRON_SECRET",
    "GITHUB_TOKEN",
    "K8O_PUSH_API_KEY"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_GOOGLE_ANALYTICS_ID",
        "TURSO_AUTH_TOKEN",
        "TURSO_DATABASE_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "type-check": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["transit"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
