{
  "name": "@repo/code-highlight",
  "version": "1.0.0",
  "private": true,
  "description": "MDXのコードブロックにシンタックスハイライトと注釈を付けるrehypeプラグイン (Shikiラッパー)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./parser": {
      "types": "./src/parser.ts",
      "default": "./src/parser.ts"
    },
    "./tokenize": {
      "types": "./src/tokenize.ts",
      "default": "./src/tokenize.ts"
    },
    "./theme": {
      "types": "./src/theme.ts",
      "default": "./src/theme.ts"
    },
    "./styles.css": "./styles/annotate.css"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@shikijs/rehype": "4.3.0",
    "shiki": "4.3.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@shikijs/types": "4.3.0",
    "@types/hast": "3.0.4",
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  }
}
