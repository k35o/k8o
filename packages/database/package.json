{
  "name": "@repo/database",
  "version": "1.0.0",
  "private": true,
  "description": "Database client for k8o project",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/db.ts",
      "storybook": "./src/__mocks__/db.ts",
      "node": "./src/db.ts",
      "default": "./src/db.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "node": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./schema": {
      "types": "./src/schema/public.ts",
      "default": "./src/schema/public.ts"
    }
  },
  "scripts": {
    "dev": "node scripts/local-db.ts serve",
    "db:serve": "node scripts/local-db.ts serve",
    "db:status": "node scripts/local-db.ts status",
    "type-check": "tsgo --noEmit",
    "generate": "drizzle-kit generate",
    "generate:custom": "drizzle-kit generate --custom",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "export:schema": "drizzle-kit export > ./schema.sql",
    "build:erd": "node --import ./scripts/register-ts-resolver.ts scripts/erd.ts"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@next/env": "catalog:",
    "@repo/typescript-config": "workspace:*",
    "drizzle-kit": "0.31.10"
  }
}
