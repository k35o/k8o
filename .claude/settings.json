{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs -r pnpm biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --colors=off --unsafe"
          },
          {
            "type": "command",
            "command": "pnpm ls-lint"
          }
        ]
      }
    ]
  }
}
